# Скопіюйте в `.env` і заповніть. Файл `.env` у репозиторій не комітиться.

SECRET_KEY=your-secret-key
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Продакшен за reverse proxy (Railway, Nginx) — TLS завершується на проксі
# BEHIND_PROXY=1

# --- Публічний доступ через ngrok (CSRF, DisallowedHost, OAuth redirect_uri) ---
# Варіант A — домен без https (рекомендовано; увімкне X-Forwarded-Proto + Secure cookies):
# NGROK_HOST=xxxx.ngrok-free.dev
# Якщо домен лише в ALLOWED_HOSTS: TRUST_X_FORWARDED_SSL=1
# Варіант B — повні origin (через кому):
# CSRF_TRUSTED_ORIGINS=https://xxxx.ngrok-free.dev
# Варіант C — файл `.ngrok-host` у корені: один рядок, лише домен (див. .ngrok-host.example)

# База даних
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# n8n (URL production webhook з workflow marketingai-chat)
# N8N_WEBHOOK_URL=https://your-n8n.app/webhook/marketingai-chat

# Chatwoot
# CHATWOOT_API_TOKEN=
# CHATWOOT_BASE_URL=https://app.chatwoot.com
# CHATWOOT_ACCOUNT_ID=
# CHATWOOT_INBOX_ID=

# WayForPay
# WAYFORPAY_MERCHANT_ACCOUNT=
# WAYFORPAY_MERCHANT_SECRET=
# WAYFORPAY_CURRENCY=EUR

# Google OAuth2 (один Web client; у Console додайте ОБА redirect URI)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# Лише календар (користувачі з паролем, кнопка SAVE → другий вхід у Google):
# GOOGLE_REDIRECT_URI=https://YOUR-NGROK.ngrok-free.dev/api/calendar/oauth/callback/
# Вхід/реєстрація + календар одним consent (рекомендовано):
# GOOGLE_SIGNIN_REDIRECT_URI=https://YOUR-NGROK.ngrok-free.dev/accounts/google/callback/
